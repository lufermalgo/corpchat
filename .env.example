# ----------------------------------------------------
# -- Project Naming Configuration
# ----------------------------------------------------
# This prefix is used to name all Docker containers, networks, and GCP resources (like Firestore collections)
# to ensure multi-client replicability and avoid naming conflicts.
# Example: corpchat
PROJECT_PREFIX=chatcopt

# ----------------------------------------------------
# -- GCP Configuration
# ----------------------------------------------------
# GCP Project ID where Firestore and Vertex AI are located.
GCP_PROJECT_ID=genai-385616

# Path to the service account credentials file mounted in the containers.
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service-account-local.json

# ----------------------------------------------------
# -- Open WebUI Configuration
# ----------------------------------------------------
# This must point to the internal Docker network address of the gateway service.
# IMPORTANT: The hostname (mychat-gateway) must match your PROJECT_PREFIX.
OPENAI_API_BASE_URL=http://chatcopt-gateway:8080/v1

# Enable Google OIDC authentication.
OIDC_ENABLED=true
OIDC_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OIDC_CLIENT_SECRET=your-google-client-secret
OIDC_ISSUER_URL=https://accounts.google.com
OIDC_SCOPES="openid email profile"
OIDC_USERNAME_CLAIM="email"

# URL that the UI is publicly accessible from.
WEBUI_URL=http://localhost:3000

# Secret key for signing sessions. Generate a random one for production.
SECRET_KEY=your-random-secret-key-for-webui
