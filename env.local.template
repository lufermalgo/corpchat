# ==========================================
# CORPCHAT LOCAL DEVELOPMENT ENVIRONMENT
# ==========================================
# Template para configuración de desarrollo local
# Copiar este archivo a .env.local y configurar las variables

# ==========================================
# ENVIRONMENT CONFIGURATION
# ==========================================
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=DEBUG

# ==========================================
# GOOGLE CLOUD CONFIGURATION
# ==========================================
# Autenticación
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service-account-local.json
GOOGLE_CLOUD_PROJECT=genai-385616
GOOGLE_CLOUD_LOCATION=us-central1

# ==========================================
# SERVICE CONFIGURATION
# ==========================================
# Identificación del servicio
SERVICE_NAME=corpchat-gateway

# URLs de servicios locales (Docker Compose)
GATEWAY_URL=http://localhost:8080
INGESTOR_URL=http://localhost:8081
UI_URL=http://localhost:8082

# URLs internas entre contenedores
GATEWAY_INTERNAL_URL=http://corpchat-gateway:8080
INGESTOR_INTERNAL_URL=http://corpchat-ingestor:8080
UI_INTERNAL_URL=http://corpchat-ui:8080

# ==========================================
# FIRESTORE CONFIGURATION
# ==========================================
# Prefijo para colecciones locales (evita conflictos con producción)
FIRESTORE_COLLECTION_PREFIX=corpchat_local

# Configuración de Firestore
FIRESTORE_DATABASE_ID=(default)

# ==========================================
# BIGQUERY CONFIGURATION
# ==========================================
# Dataset para desarrollo local
BIGQUERY_DATASET=corpchat_local
BIGQUERY_TABLE_EMBEDDINGS=embeddings_local
BIGQUERY_TABLE_METADATA=metadata_local

# Configuración de embeddings
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768

# ==========================================
# CLOUD STORAGE CONFIGURATION
# ==========================================
# Bucket para archivos (usar el mismo que producción para desarrollo)
GCS_BUCKET_ATTACHMENTS=corpchat-genai-385616-attachments

# Prefijo para archivos locales
GCS_PREFIX_LOCAL=local-dev/

# ==========================================
# VERTEX AI CONFIGURATION
# ==========================================
# Modelos Gemini
DEFAULT_MODEL=gemini-2.5-flash-001
FALLBACK_MODEL=gemini-1.5-flash-001
THINKING_MODEL=gemini-2.5-flash-001

# Configuración de modelos
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=8192
MODEL_TOP_P=0.95
MODEL_TOP_K=40

# ==========================================
# SPEECH-TO-TEXT CONFIGURATION
# ==========================================
# Configuración STT para desarrollo local
STT_MODEL_SHORT=latest_short
STT_MODEL_LONG=latest_long
STT_LANGUAGE_CODE=es-ES
STT_SAMPLE_RATE=16000

# ==========================================
# OPEN WEBUI CONFIGURATION
# ==========================================
# URLs para Open WebUI (servicios locales)
OPENWEBUI_GATEWAY_URL=http://corpchat-gateway:8080
OPENWEBUI_INGESTOR_URL=http://corpchat-ingestor:8080

# Configuración STT para Open WebUI
AUDIO_STT_ENGINE=openai
AUDIO_STT_MODEL=whisper-1
AUDIO_STT_OPENAI_API_BASE_URL=http://corpchat-gateway:8080/v1/audio
AUDIO_STT_OPENAI_API_KEY=corpchat-gateway

# Configuración de acumulación de texto
AUDIO_STT_APPEND_MODE=true
AUDIO_STT_CONTINUOUS_MODE=true

# ==========================================
# MEMORY CONFIGURATION
# ==========================================
# Configuración de memoria híbrida
MEMORY_WORKING_SIZE=10
MEMORY_LONG_TERM_SIZE=50
MEMORY_CONSOLIDATION_THRESHOLD=5

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
# Configuración de logging para desarrollo
LOG_FORMAT=detailed
LOG_INCLUDE_TRACEBACK=true
LOG_STRUCTURED=true

# Labels para logging
LOG_PROJECT=corpchat
LOG_SERVICE=local-development
LOG_TEAM=corpchat-dev

# ==========================================
# DEVELOPMENT TOOLS
# ==========================================
# Herramientas de desarrollo
ENABLE_DEBUG_ENDPOINTS=true
ENABLE_METRICS_ENDPOINTS=true
ENABLE_HEALTH_CHECKS=true

# Hot reload para desarrollo
ENABLE_HOT_RELOAD=true
WATCH_FILES=true

# ==========================================
# TESTING CONFIGURATION
# ==========================================
# Configuración para tests
TEST_MODE=false
MOCK_EXTERNAL_SERVICES=false
TEST_DATA_PREFIX=test_

# ==========================================
# SECURITY CONFIGURATION
# ==========================================
# Configuración de seguridad (desarrollo)
CORS_ALLOWED_ORIGINS=http://localhost:8082,http://127.0.0.1:8082
CORS_ALLOW_CREDENTIALS=true

# Autenticación (deshabilitada para desarrollo local)
AUTH_REQUIRED=false
AUTH_TOKEN=corpchat-gateway-dev

# ==========================================
# PERFORMANCE CONFIGURATION
# ==========================================
# Configuración de performance para desarrollo
WORKER_COUNT=1
MAX_CONNECTIONS=100
TIMEOUT_SECONDS=30

# Cache configuration
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300

# ==========================================
# MONITORING CONFIGURATION
# ==========================================
# Métricas y monitoreo
METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30

# ==========================================
# DOCKER CONFIGURATION
# ==========================================
# Configuración específica de Docker
DOCKER_NETWORK=corpchat-local
DOCKER_NAMESPACE=corpchat

# ==========================================
# PORT CONFIGURATION
# ==========================================
# Puertos para servicios locales
GATEWAY_PORT=8080
INGESTOR_PORT=8081
UI_PORT=8082
METRICS_PORT=9090

# ==========================================
# EXTERNAL SERVICES (OPCIONAL)
# ==========================================
# Configuración para servicios externos si se necesitan
# PUBSUB_TOPIC=corpchat-local
# REDIS_URL=redis://localhost:6379
# ELASTICSEARCH_URL=http://localhost:9200

# ==========================================
# NOTES
# ==========================================
# Este archivo es un template. Copiar a .env.local y modificar según necesidades.
# 
# Variables importantes para configurar:
# 1. GOOGLE_APPLICATION_CREDENTIALS - Ruta al archivo de credenciales
# 2. GOOGLE_CLOUD_PROJECT - ID del proyecto GCP
# 3. FIRESTORE_COLLECTION_PREFIX - Prefijo para evitar conflictos
# 4. BIGQUERY_DATASET - Dataset para desarrollo local
# 5. GCS_BUCKET_ATTACHMENTS - Bucket para archivos
#
# Para más información, ver:
# - docs/LOCAL_AUTH_SETUP.md
# - docs/LOCAL_DEVELOPMENT_GUIDE.md
# - docs/TROUBLESHOOTING_LOCAL.md
